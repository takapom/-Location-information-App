{
  "name": "terri",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.11.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "mobile:start": "pnpm --filter @terri/mobile start",
    "mobile:test": "pnpm --filter @terri/mobile test",
    "mobile:typecheck": "pnpm --filter @terri/mobile typecheck",
    "test": "pnpm --filter @terri/mobile test",
    "typecheck": "pnpm --filter @terri/mobile typecheck"
  },
  "devDependencies": {
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-test-renderer": "19.1.0"
  },
  "overrides": {
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-test-renderer": "19.1.0"
  }
}
